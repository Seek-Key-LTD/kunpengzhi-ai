# LLM 配置（二选一）
OPENAI_API_KEY=sk-xxx                  # OpenAI 兼容 API
OPENAI_BASE_URL=https://api.openai.com/v1
DEBATE_MODEL=gemini-2.5-flash          # Gemini via Vertex

# Wiki.js 知识库（可选）
WIKI_JS_URL=https://wiki.your.domain/graphql
WIKI_JS_TOKEN=your_token

# 链式认证
APP_PASSWORD=3131                      # 登录密码

# 微软免费 TTS（无需 API Key）
TTS_VOICE=zh-CN-YunxiNeural           # 中文男声（云希）
TTS_ENABLED=true                       # 开启语音
